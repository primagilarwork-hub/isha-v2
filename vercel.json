{
  "version": 2,
  "builds": [
    { "src": "api/**/*.py", "use": "@vercel/python" },
    { "src": "webapp/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook.py" },
    { "src": "/api/cron/reminder", "dest": "/api/cron/reminder.py" },
    { "src": "/api/health", "dest": "/api/health.py" },
    { "src": "/api/miniapp/dashboard", "dest": "/api/miniapp/dashboard.py" },
    { "src": "/api/miniapp/expenses(.*)", "dest": "/api/miniapp/expenses.py" },
    { "src": "/api/miniapp/budgets(.*)", "dest": "/api/miniapp/budgets.py" },
    { "src": "/api/miniapp/reports(.*)", "dest": "/api/miniapp/reports.py" },
    { "src": "/webapp/(.*)", "dest": "/webapp/$1" },
    { "src": "/", "dest": "/webapp/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/reminder",
      "schedule": "0 14 * * *"
    }
  ]
}
